# SFx Burger OMS — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local must NEVER be committed to version control.
#
# Find these values in: Supabase Dashboard → Settings → API

# Public — exposed to browser (safe)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Private — server-side only, NEVER expose to the browser.
# Used by server actions to bypass RLS for sequence counter generation (PRD §8).
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
